PORT=3000
APP_URL=http://localhost:3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=harvesthub
DB_SSL=false
# TiDB Cloud / managed MySQL: DB_SSL=true
# DB_SSL_CA=/etc/ssl/cert.pem

JWT_SECRET=generate-a-long-random-string
JWT_EXPIRES_IN=30d

UPLOAD_DIR=./uploads

# console / none / stub = no real SMS → OTP is always OTP_DEV_CODE
SMS_PROVIDER=console
SMS_API_KEY=
OTP_DEV_CODE=000000

PAYMENT_PROVIDER=mock
PAYMENT_KEY_ID=
PAYMENT_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=

ADMIN_API_KEY=harvesthub-admin-dev-key
